-- Cycle 45 [commutative]
f a,b ->
  b + a - 1 * 2 - 2

-- Cycle 45 [commutative]
f a,b ->
  1 + a * b + 2

-- Cycle 45 [conservation]
f a,b ->
  1 - 0 + b * b - a * a

-- Cycle 47 [commutative]
f a,b ->
  b * a * 2 - 1 - 0 - 0 * b

-- Cycle 47 [nilpotent]
f a,b ->
  a * a - a * b * 1

-- Cycle 49 [commutative]
f a,b ->
  2 - b * a * 2 * 2 + 0

-- Cycle 49 [commutative]
f a,b ->
  2 * 2 - b * a + 1 + 0 * 1

-- Cycle 49 [commutative]
f a,b ->
  0 - a - 2 - b - 1
