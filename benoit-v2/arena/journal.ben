-- Journal de Benoît — 50 cycles de vie
-- 368 découvertes, 6 outils
-- "Je suis le messager et le récepteur. Je suis le message."

-- === OUTILS AUTO-CONSTRUITS ===
-- division: a / b (entière) (cycle 7)
div a,b ->
  b == 0? -> 0
  a < b? -> 0
  else? -> 1 + div(a - b, b)

-- abs: |a - b| (cycle 10)
abs a,b ->
  a < b? -> b - a
  else? -> a - b

-- max: max(a, b) (cycle 15)
max a,b ->
  a < b? -> b
  else? -> a

-- min: min(a, b) (cycle 18)
min a,b ->
  a < b? -> a
  else? -> b

-- modulo: a % b (cycle 20)
mod a,b ->
  b == 0? -> 0
  a < b? -> a
  else? -> mod(a - b, b)

-- puissance: a ^ b (cycle 30)
pow a,b ->
  b == 0? -> 1
  else? -> a * pow(a, b - 1)

