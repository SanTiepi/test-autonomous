-- journal (auto-généré tick 9400000)
-- État: sain, 63/75 actifs, 330 conns, score 2, fails 1

moment_tick: 9400000
moment_etat: "sain"
moment_actifs: 63
moment_N: 75
moment_conns: 330
moment_score: 2
moment_fails: 1
moment_decision: "explorer"

_sante a, n ->
  a * 100 / n > 70? -> "fort"
  a * 100 / n > 40? -> "stable"
  else? -> "fragile"

sante: _sante(moment_actifs, moment_N)
