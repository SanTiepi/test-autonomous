-- journal (auto-généré tick 18090000)
-- État: transparent, 10/30 actifs, 70 conns, score 2, fails 1

moment_tick: 18090000
moment_etat: "transparent"
moment_actifs: 10
moment_N: 30
moment_conns: 70
moment_score: 2
moment_fails: 1
moment_decision: "augmenter_inhibition"

_sante a, n ->
  a * 100 / n > 70? -> "fort"
  a * 100 / n > 40? -> "stable"
  else? -> "fragile"

sante: _sante(moment_actifs, moment_N)
