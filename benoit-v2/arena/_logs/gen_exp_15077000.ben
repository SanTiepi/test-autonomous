score_before: 0
score_after: 0
seuil_change: -1

_helped b, a ->
  a > b? -> "oui"
  a == b? -> "neutre"
  else? -> "non"

_should_change s, m ->
  s < 3? -> "changer"
  else? -> "garder"

verdict: _helped(score_before, score_after)
action: _should_change(score_before, 0)
