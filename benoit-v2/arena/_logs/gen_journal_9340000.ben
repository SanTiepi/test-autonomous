-- journal (auto-généré tick 9340000)
-- État: sain, 25/30 actifs, 90 conns, score 2, fails 4

moment_tick: 9340000
moment_etat: "sain"
moment_actifs: 25
moment_N: 30
moment_conns: 90
moment_score: 2
moment_fails: 4
moment_decision: "augmenter_seuils"

_sante a, n ->
  a * 100 / n > 70? -> "fort"
  a * 100 / n > 40? -> "stable"
  else? -> "fragile"

sante: _sante(moment_actifs, moment_N)
