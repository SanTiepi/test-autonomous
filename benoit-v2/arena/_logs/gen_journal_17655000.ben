-- journal (auto-généré tick 17655000)
-- État: transparent, 10/30 actifs, 70 conns, score 3, fails 0

moment_tick: 17655000
moment_etat: "transparent"
moment_actifs: 10
moment_N: 30
moment_conns: 70
moment_score: 3
moment_fails: 0
moment_decision: "augmenter_inhibition"

_sante a, n ->
  a * 100 / n > 70? -> "fort"
  a * 100 / n > 40? -> "stable"
  else? -> "fragile"

sante: _sante(moment_actifs, moment_N)
