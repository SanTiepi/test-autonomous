moment_tick: 9495000
moment_etat: "saturé"
moment_actifs: 50
moment_N: 50
moment_conns: 555
moment_score: 2
moment_fails: 3
moment_decision: "augmenter_seuils"

_sante a, n ->
  a * 100 / n > 70? -> "fort"
  a * 100 / n > 40? -> "stable"
  else? -> "fragile"

sante: _sante(moment_actifs, moment_N)
