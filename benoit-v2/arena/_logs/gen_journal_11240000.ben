-- journal (auto-généré tick 11240000)
-- État: transparent, 15/30 actifs, 95 conns, score 3, fails 0

moment_tick: 11240000
moment_etat: "transparent"
moment_actifs: 15
moment_N: 30
moment_conns: 95
moment_score: 3
moment_fails: 0
moment_decision: "augmenter_inhibition"

_sante a, n ->
  a * 100 / n > 70? -> "fort"
  a * 100 / n > 40? -> "stable"
  else? -> "fragile"

sante: _sante(moment_actifs, moment_N)
